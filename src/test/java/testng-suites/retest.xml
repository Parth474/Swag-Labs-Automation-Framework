<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RetestSuite">
	<parameter name="user" value="problem_user"></parameter>
	<listeners>
        <listener class-name="listner.Listner"/>
    </listeners>

	<test name="RetestFailedCases">
		<classes>
			<class name="tests.ProductPageTest">
				<methods>
					<include name="verifyFirstProductDetails"/>
					<include name="verifyLastProductDetails"/>
					<include name="verifyAddToCart"/>
					<include name="verifyRemoveFromCart"/>
				</methods>
			</class>
		</classes>
	</test>
</suite>